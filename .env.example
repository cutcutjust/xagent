# ── LLM ────────────────────────────────────────────────────
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=Qwen3.6-Plus
LLM_VISION_MODEL=Qwen3.6-Plus
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# ── Notion ─────────────────────────────────────────────────
NOTION_TOKEN=ntn_your-token-here
NOTION_RESEARCH_DB_ID=your-research-database-id
NOTION_TEMPLATE_DB_ID=your-template-database-id
NOTION_DRAFT_DB_ID=your-draft-database-id

# ── Browser ────────────────────────────────────────────────
BROWSER_PROFILE_DIR=~/.sightops/browser_profile
BROWSER_HEADLESS=false
BROWSER_SLOW_MO=50

# ── Assets ─────────────────────────────────────────────────
ASSETS_DIR=~/ai-content-assets

# ── App ────────────────────────────────────────────────────
LOG_LEVEL=INFO
DATA_DIR=./data
